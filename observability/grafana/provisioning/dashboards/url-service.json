{
  "title": "URL Service",
  "uid": "url-service",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [

    { "id": 10, "title": "Traffic", "type": "row", "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total[1m])) by (method, endpoint, status)",
          "legendFormat": "{{method}} {{endpoint}} {{status}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "Total Requests (counter)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(http_requests_total)",
          "legendFormat": "Total requests"
        }
      ]
    },

    { "id": 20, "title": "Latency", "type": "row", "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 2,
      "title": "Request Latency Percentiles (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 10, "w": 16, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.3 },
            { "color": "red", "value": 0.5 }
          ]}
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 21,
      "title": "P95 Latency (current)",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 10, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.3 },
            { "color": "red", "value": 0.5 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },

    { "id": 30, "title": "Errors", "type": "row", "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 3,
      "title": "Error Rate (5xx/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 19, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 0.01 }
          ]}
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_errors_total[1m])) by (method, endpoint)",
          "legendFormat": "{{method}} {{endpoint}}"
        }
      ]
    },
    {
      "id": 31,
      "title": "Error Ratio (%)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 19, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.01 },
            { "color": "red", "value": 0.05 }
          ]}
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_errors_total[2m])) / sum(rate(http_requests_total[2m]))",
          "legendFormat": "error ratio"
        }
      ]
    },

    { "id": 40, "title": "Saturation", "type": "row", "gridPos": { "x": 0, "y": 27, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 41,
      "title": "In-Flight Requests",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 30 },
            { "color": "red", "value": 50 }
          ]}
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "http_requests_in_progress",
          "legendFormat": "in-flight"
        }
      ]
    },
    {
      "id": 42,
      "title": "Database Up",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "db_up",
          "legendFormat": "database"
        }
      ]
    },

    { "id": 50, "title": "Logs", "type": "row", "gridPos": { "x": 0, "y": 36, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 4,
      "title": "Application Logs",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 37, "w": 24, "h": 10 },
      "options": { "showTime": true, "showLabels": true, "wrapLogMessage": true, "sortOrder": "Descending", "dedupStrategy": "none" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"url-service\"}",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 5,
      "title": "Error Logs",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 47, "w": 24, "h": 10 },
      "options": { "showTime": true, "showLabels": true, "wrapLogMessage": true, "sortOrder": "Descending" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"url-service\", level=\"ERROR\"}",
          "legendFormat": ""
        }
      ]
    }
  ]
}
